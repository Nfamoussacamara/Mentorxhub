}

/* Tables */
.table-container {
    overflow-x: auto;
    background-color: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
}

table {
    width: 100%;
    border-collapse: collapse;
}

th,
td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
}

th {
    background-color: var(--color-surface);
    font-weight: 600;
    cursor: pointer;
    user-select: none;
}

th:hover {
    background-color: #e5e7eb;
}

tr:last-child td {
    border-bottom: none;
}

tr:hover {
    background-color: #f9fafb;
}

.sort-icon {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.8rem;
}

/* Auth Pages Redesign */
.auth-container {
    display: flex;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
}

.auth-left {
    display: none;
    width: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f172a 100%);
    color: white;
    flex-direction: column;
    justify-content: center;
    padding: 4rem;
    position: relative;
}

/* Decorative circles for the left side */
.auth-left::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
}

.auth-left::after {
    content: '';
    position: absolute;
    bottom: -5%;
    left: -5%;
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
}

.auth-brand {
    position: relative;
    z-index: 1;
}

.auth-brand h1 {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.1;
}

.auth-brand p {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 80%;
}

.auth-right {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: white;
    position: relative;
}

.auth-form-container {
    width: 100%;
    max-width: 420px;
    padding: 2rem;
}

.auth-back-link {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-weight: 500;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
}

.auth-back-link:hover {
    color: var(--color-primary);
}

/* Social Login Buttons (Mock) */
.social-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: white;
    font-weight: 500;
    color: var(--color-text);
    transition: all 0.2s;
    cursor: pointer;
    margin-bottom: 1rem;
}

.social-btn:hover {
    background-color: #f9fafb;
    border-color: #d1d5db;
}

.divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--color-border);
}

.divider::before {
    margin-right: 1rem;
}

.divider::after {
    margin-left: 1rem;
}

@media (min-width: 768px) {
    .auth-left {
        display: flex;
    }

    .auth-right {
        width: 50%;
    }
}

```