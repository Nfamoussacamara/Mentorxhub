{% load static %}
{% load custom_filters %}
{% url 'dashboard:dashboard' as dashboard_url %}
{% url 'mentoring:mentors_list' as mentors_list_url %}
{% url 'accounts:profile' as profile_url %}
{% url 'accounts:logout' as logout_url %}

<aside class="dashboard-sidebar" id="dashboard-sidebar">
    <div class="sidebar-header">
        <a href="{% url 'core:home' %}" class="sidebar-brand">
            <div class="brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <span class="brand-text">MentorXHub</span>
        </a>
        <button class="sidebar-collapse-btn" id="sidebar-collapse-btn" aria-label="Réduire le menu" title="Réduire le menu">
            <i class="fas fa-angles-left"></i>
            <i class="fas fa-angles-right"></i>
        </button>
        <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
            <i class="fas fa-bars"></i>
        </button>
    </div>
    
    <nav class="sidebar-nav">
        <!-- Vue d'ensemble (Active) -->
        <a href="{{ dashboard_url }}" class="nav-item {% if request.resolver_match.url_name == 'dashboard' or request.resolver_match.url_name == 'home' %}active{% endif %}">
            <i class="fas fa-comment-dots"></i>
            <span class="nav-label">Vue d'ensemble</span>
        </a>
        
        <!-- Sessions -->
        <a href="{% url 'dashboard:analytics' %}" class="nav-item {% if request.resolver_match.url_name == 'analytics' %}active{% endif %}">
            <i class="fas fa-briefcase"></i>
            <span class="nav-label">Sessions</span>
        </a>
        
        <!-- Mentors -->
        <a href="{{ mentors_list_url }}" class="nav-item">
            <i class="fas fa-building"></i>
            <span class="nav-label">Mentors</span>
        </a>
        
        <!-- Rapports -->
        <a href="{% url 'dashboard:analytics' %}" class="nav-item {% if request.resolver_match.url_name == 'analytics' %}active{% endif %}">
            <i class="fas fa-chart-pie"></i>
            <span class="nav-label">Rapports</span>
        </a>
        
        <!-- Messagerie -->
        <a href="{% url 'dashboard:messages_list' %}" class="nav-item {% if request.resolver_match.url_name|startswith:'message' %}active{% endif %}">
            <i class="fas fa-comments"></i>
            <span class="nav-label">Messagerie</span>
            <span class="nav-badge" id="messages-unread-badge" style="display: none;">0</span>
        </a>
        
        <!-- Cours -->
        <a href="{% url 'dashboard:courses_list' %}" class="nav-item {% if request.resolver_match.url_name|startswith:'course' %}active{% endif %}">
            <i class="fas fa-file-alt"></i>
            <span class="nav-label">Cours</span>
        </a>
        
        <div class="sidebar-divider"></div>
        
        <a href="{% url 'dashboard:profile' %}" class="nav-item">
            <i class="fas fa-user"></i>
            <span class="nav-label">Mon Profil</span>
        </a>
        <a href="{% url 'dashboard:settings' %}" class="nav-item {% if request.resolver_match.url_name == 'settings' or request.resolver_match.url_name|startswith:'settings' %}active{% endif %}">
            <i class="fas fa-cog"></i>
            <span class="nav-label">Paramètres</span>
        </a>
        <a href="{{ logout_url }}" class="nav-item nav-item-danger">
            <i class="fas fa-sign-out-alt"></i>
            <span class="nav-label">Déconnexion</span>
        </a>
    </nav>
    
    <!-- Zone de redimensionnement -->
    <div class="sidebar-resizer" id="sidebar-resizer"></div>
</aside>

